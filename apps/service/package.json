{
  "name": "@staff-report/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --no-warn-ignored",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "express": "^5.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.0",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@staff-report/eslint-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^24.13.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9.25.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.0"
  }
}
